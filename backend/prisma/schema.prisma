generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id        String   @id @default(uuid())
  name      String
  // Múi giờ mặc định của tổ chức (offset cố định, không tự DST). Format "+07:00" / "-05:00".
  // Mặc định +07:00 (Việt Nam) để mọi timestamp render trong UI và log đều đồng nhất, dễ decode.
  timezone  String   @default("+07:00")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams                Team[]
  users                User[]
  zaloAccounts         ZaloAccount[]
  contacts             Contact[]
  conversations        Conversation[]
  appointments         Appointment[]
  activityLogs         ActivityLog[]
  dailyStats           DailyMessageStat[]
  settings             AppSetting[]
  duplicateGroups      DuplicateGroup[]
  savedReports         SavedReport[]
  integrations         Integration[]
  automationRules      AutomationRule[]
  messageTemplates     MessageTemplate[]
  aiConfig             AiConfig?
  aiSuggestions        AiSuggestion[]
  pinnedConversations  PinnedConversation[]
  groupPolls           GroupPoll[]
  friendshipAttempts   FriendshipAttempt[]
  friends              Friend[]
  statuses             Status[]
  parentCandidates     ParentCandidate[]
  notes                Note[]
  zaloLabels           ZaloLabel[]
  crmTags              CrmTag[]
  crmTagGroups         CrmTagGroup[]
  // Phase 6 — Lead Scoring Engine relations
  scoringConfig        ScoringConfig?
  scoreSignalRules     ScoreSignalRule[]
  stageTransitionRules StageTransitionRule[]
  stuckThresholds      StuckThreshold[]
  nbaTemplates         NbaTemplate[]
  // Phase 6+ — Inbox Triage Filter relations
  accountFolders       AccountFolder[]
  savedFilterPresets   SavedFilterPreset[]
  // Phase 7 — Automation framework (Block / Sequence / Trigger / Broadcast / Campaign / Task)
  blocks               Block[]
  blockFolders         BlockFolder[]
  automationSequences  AutomationSequence[]
  automationTriggers   AutomationTrigger[]
  automationBroadcasts AutomationBroadcast[]
  automationCampaigns  AutomationCampaign[]
  automationTasks      AutomationTask[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org                       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team                      Team?               @relation(fields: [teamId], references: [id])
  zaloAccounts              ZaloAccount[]
  zaloAccess                ZaloAccountAccess[]
  assignedContacts          Contact[]           @relation("AssignedContacts")
  appointments              Appointment[]
  statusChangedAppointments Appointment[]       @relation("AppointmentStatusChanger")
  repliedMessages           Message[]           @relation("RepliedMessages")
  activityLogs              ActivityLog[]
  messageTemplates          MessageTemplate[]
  authoredNotes             Note[]              @relation("NoteAuthor")
  noteReactions             NoteReaction[]
  preferences               UserPreference[]
  // Phase 6+ — Inbox Triage Filter (per-user)
  accountFolders            AccountFolder[]
  savedFilterPresets        SavedFilterPreset[]
  // Phase 7 — Automation framework (createdBy backrefs)
  createdBlocks             Block[]                @relation("BlockCreatedBy")
  createdBlockFolders       BlockFolder[]          @relation("BlockFolderCreatedBy")
  ownedBlockFolders         BlockFolder[]          @relation("BlockFolderOwnerUser")
  createdSequences          AutomationSequence[]   @relation("SequenceCreatedBy")
  createdTriggers           AutomationTrigger[]    @relation("TriggerCreatedBy")
  createdBroadcasts         AutomationBroadcast[]  @relation("BroadcastCreatedBy")

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  proxyUrl        String?   @map("proxy_url") // per-account proxy (PR#11)
  sessionData     Json?     @map("session_data")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org                Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner              User                  @relation(fields: [ownerUserId], references: [id])
  access             ZaloAccountAccess[]
  conversations      Conversation[]
  dailyStats         DailyMessageStat[]
  friendshipAttempts FriendshipAttempt[]
  friends            Friend[]
  zaloLabelsList     ZaloLabel[]
  crmTagGroups       CrmTagGroup[]
  // Phase 6+ — Inbox Triage Filter (junction folder membership)
  folderMembers      AccountFolderMember[]
  // Phase 7 — Automation framework
  ownedBlocks        Block[]               @relation("BlockOwnerNick")
  ownedBlockFolders  BlockFolder[]         @relation("BlockFolderOwnerNick")
  assignedTasks      AutomationTask[]      @relation("TaskAssignedNick")

  // Phase 7 — Per-nick automation caps (configurable, default theo memory rule:
  //   300 msg/day/nick, 30-50 friend-add/day/nick)
  dailyFriendAddCap  Int                   @default(30)  @map("daily_friend_add_cap")
  dailyMessageCap    Int                   @default(300) @map("daily_message_cap")
  // Per-nick throttle gate cross-campaign (memory: project_zalocrm_per_nick_throttle_gate)
  lastFriendReqSentAt DateTime?            @map("last_friend_req_sent_at")
  lastMessageSentAt   DateTime?            @map("last_message_sent_at")

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  // Zalo identifiers toàn cục — KHÔNG đổi giữa các account viewer (khác với zaloUid per-account).
  // Dùng làm khóa dedup chính: cùng person từ 2 account CRM khác nhau có cùng zaloGlobalId.
  zaloGlobalId     String?   @map("zalo_global_id")
  zaloUsername     String?   @map("zalo_username")
  phone            String?
  // Canonical SĐT (84xxx no +/space) — auto-derive từ `phone` qua normalizePhone()
  // trên mọi write path. Index để search exact O(log n), dedup chính xác cross-format
  // (0xxx ↔ 84xxx ↔ +84xxx cùng map về 84xxx). Hiện chỉ index phone chính; phone2/3
  // vẫn search via contains variants vì ít dùng.
  phoneNormalized  String?   @map("phone_normalized")
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  crmName          String?   @map("crm_name")
  avatarUrl        String?   @map("avatar_url")
  source           String? // FB, TT, GT, CN, phone_import, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // LEGACY: new/contacted/interested/converted/lost — giữ 1 release, sau drop. Field mới: statusId FK -> Status table
  statusId         String?   @map("status_id")
  // ── Parent-Child (KH cha gom nhiều KH con — cross-Zalo-identity human-level link) ───
  // Khác mergedInto (hard-merge same Zalo identity, secondary hidden): parentContactId
  // soft-link, child visible, aggregate status/score/hasZalo từ children. Canonical son
  // làm cha → parentContactId=NULL cho cha, các con khác trỏ về.
  parentContactId  String?   @map("parent_contact_id")
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  tags             Json      @default("[]") // CRM tags do sale gắn ("vip","quan_tam_3pn",...). Auto tag prefix "auto:"
  metadata         Json      @default("{}")
  leadScore        Int       @default(0) @map("lead_score")
  lastActivity     DateTime? @map("last_activity")
  mergedInto       String?   @map("merged_into")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // ── Discovery via friend-request attempt ─────────────────────────────────
  hasZalo            Boolean?  @map("has_zalo") // null=unknown, true=verified yes, false=verified no
  zaloLookupAt       DateTime? @map("zalo_lookup_at")
  zaloLookupAttempts Int       @default(0) @map("zalo_lookup_attempts")
  importBatchId      String?   @map("import_batch_id") // soft FK -> phone_list_imports.id (model later)

  // ── Compliance ─────────────────────────────────────────────────────────────
  consentStatus    String    @default("implicit") @map("consent_status") // implicit/granted/revoked
  consentRevokedAt DateTime? @map("consent_revoked_at")
  consentSource    String?   @map("consent_source") // form_landing, opt_in_msg, manual, ...

  // ── Multi-phone ────────────────────────────────────────────────────────────
  phone2      String? @map("phone_2")
  phone3      String? @map("phone_3")
  phonesExtra Json    @default("[]") @map("phones_extra") // [{phone,label},...]

  // ── Demographic / BĐS profile ──────────────────────────────────────────────
  province       String?
  district       String?
  ward           String?
  addressLine    String?   @map("address_line")
  gender         String? // male/female/other/unknown
  birthYear      Int?      @map("birth_year")
  birthDate      DateTime? @map("birth_date") @db.Date
  occupation     String?
  incomeRange    String?   @map("income_range")
  socialFacebook String?   @map("social_facebook")
  socialTiktok   String?   @map("social_tiktok")
  preferredLang  String?   @default("vi") @map("preferred_lang")

  // ── Aggregate: tin nhắn cuối từ KHÁCH (inbound) ───────────────────────────
  lastInboundAt        DateTime? @map("last_inbound_at")
  lastInboundMessageId String?   @map("last_inbound_message_id")
  lastInboundPreview   String?   @map("last_inbound_preview")
  lastInboundType      String?   @map("last_inbound_type")

  // ── Aggregate: tin nhắn cuối từ SALE (outbound) ───────────────────────────
  lastOutboundAt              DateTime? @map("last_outbound_at")
  lastOutboundMessageId       String?   @map("last_outbound_message_id")
  lastOutboundPreview         String?   @map("last_outbound_preview")
  lastOutboundType            String?   @map("last_outbound_type")
  lastOutboundByUserId        String?   @map("last_outbound_by_user_id") // soft FK
  lastOutboundByZaloAccountId String?   @map("last_outbound_by_zalo_account_id") // soft FK

  // ── Aggregate: tương tác cuối (reaction/recall/edit/...) ──────────────────
  lastInteractionAt      DateTime? @map("last_interaction_at")
  lastInteractionType    String?   @map("last_interaction_type")
  lastInteractionPayload Json?     @map("last_interaction_payload")

  // ── Counters (cache) ───────────────────────────────────────────────────────
  totalInbound      Int @default(0) @map("total_inbound")
  totalOutbound     Int @default(0) @map("total_outbound")
  totalAppointments Int @default(0) @map("total_appointments")

  org               Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser      User?               @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  mergedIntoContact Contact?            @relation("ContactMerge", fields: [mergedInto], references: [id])
  mergedFrom        Contact[]           @relation("ContactMerge")
  parent            Contact?            @relation("ContactFather", fields: [parentContactId], references: [id], onDelete: SetNull)
  children          Contact[]           @relation("ContactFather")
  statusRef         Status?             @relation(fields: [statusId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  appointments      Appointment[]
  attempts          FriendshipAttempt[]
  friends           Friend[]
  contactNotes      Note[]
  // Phase 7 — Automation framework
  automationTasks   AutomationTask[]

  // Per-Contact counters (cache from Friend rows; updated by friend-aggregate hooks)
  acceptedNicksCount Int @default(0) @map("accepted_nicks_count")
  pendingNicksCount  Int @default(0) @map("pending_nicks_count")
  chattingNicksCount Int @default(0) @map("chatting_nicks_count")

  // ── Phase 6: Aggregate Lead Scoring fields ─────────────────────────────
  // Aggregated từ Friend rows. Trigger: sau mỗi Friend.score thay đổi.
  // Logic: Contact.leadScore = MAX(Friend.leadScore), aggregateBreakdown =
  // breakdown của Friend có leadScore cao nhất, ownerFriendId trỏ tới đó.
  // Render: Manager view / dashboard / list dùng Contact.leadScore.
  // Sale view (chat panel cột 3-4) dùng Friend.leadScore của nick đang active.
  aggregateScoreUpdatedAt DateTime? @map("aggregate_score_updated_at")
  // ownerFriendId: Friend.id có leadScore cao nhất + inbound recent 14d.
  // Soft FK (không enforce qua relation) vì Friend cascade-delete sẽ NULL cell này.
  ownerFriendId           String?   @map("owner_friend_id")
  aggregateBreakdown      Json      @default("{}") @map("aggregate_breakdown")
  // autoTags aggregated: UNION từ tất cả Friend.autoTags, dedupe.
  autoTags                Json      @default("[]") @map("auto_tags")
  // stuckSinceAggregate: MIN(Friend.stuckSince) khi TẤT CẢ Friend đều stuck.
  // Nếu có ít nhất 1 Friend không stuck → null (KH vẫn có "đường" qua nick khác).
  stuckSinceAggregate     DateTime? @map("stuck_since_aggregate")

  // ── Phase 8: Engagement Heatmap Timeline ────────────────────────────────
  // Pattern classification derived từ ContactEngagementDaily 4-week rolling window.
  // Updated bởi daily cron 02:30 VN time.
  // Values: hot | champion | stable | cooling | cold | noise (chưa đủ data)
  engagementPattern   String?   @map("engagement_pattern")
  // Trend % change tuần này vs tuần trước (-100 to +∞, clamp display -100..200)
  engagementTrend     Int?      @map("engagement_trend")
  // Avg dailyIntensity 28 days (0-100). Snapshot quality.
  engagementScore     Int?      @map("engagement_score")
  engagementUpdatedAt DateTime? @map("engagement_updated_at")

  // ── Phase 8.C: Priority Score (combined) ───────────────────────────────
  // Formula: leadScore × 0.55 + engagementScore × 0.30 + trendBoost
  // trendBoost: engagementTrend ≥ 20 → +10; ≤ -20 → -5; else 0
  // Clamp 0-100. Recompute trên mỗi lead/engagement update + daily cron.
  priorityScore       Int?      @map("priority_score")
  priorityUpdatedAt   DateTime? @map("priority_updated_at")

  // Daily engagement aggregate rows (cascade delete)
  engagementDaily ContactEngagementDaily[]

  @@unique([orgId, zaloGlobalId])
  @@index([orgId, phone])
  @@index([orgId, phoneNormalized])
  @@index([orgId, zaloUid])
  // Default sort cho ContactsView list: tương tác mới nhất lên đầu.
  // Cần index để tránh seq scan khi 4500+ contacts.
  @@index([orgId, lastActivity])
  @@index([orgId, priorityScore(sort: Desc)])
  @@index([orgId, zaloUsername])
  @@index([orgId, mergedInto])
  @@index([orgId, hasZalo])
  @@index([orgId, importBatchId])
  @@index([orgId, consentStatus])
  @@index([orgId, province, district])
  @@index([orgId, lastInboundAt])
  @@index([orgId, lastOutboundAt])
  @@index([orgId, status, lastInboundAt])
  @@index([phone2])
  @@index([phone3])
  @@index([orgId, acceptedNicksCount])
  @@index([orgId, parentContactId])
  @@index([orgId, statusId])
  // Phase 6 aggregate indexes
  @@index([orgId, leadScore(sort: Desc)])
  @@index([orgId, stuckSinceAggregate])
  @@index([orgId, aggregateScoreUpdatedAt(sort: Desc)])
  @@map("contacts")
}

// Status (Trạng thái KH) — per-org config replacing Contact.status enum cũ.
// Default seed 8 status: Mới/Tiếp cận/Hẹn gặp/Nóng/Tiềm năng/Chốt/Thất Bại/Mất.
// `order` Int: dùng cho aggregation Cha = MAX(sons.status.order).
// `isTerminal`: status kết thúc (Chốt/Thất Bại/Mất) — UI có thể style khác.
// `isDefault`: 1 status được flag default cho Contact mới (Mới).
model Status {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  name       String
  order      Int      @default(0)
  color      String?
  isTerminal Boolean  @default(false) @map("is_terminal")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts Contact[]
  friends  Friend[]

  @@unique([orgId, name])
  @@index([orgId, order])
  @@map("statuses")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  zaloAccountId     String    @map("zalo_account_id")
  contactId         String?   @map("contact_id")
  threadType        String    @default("user") // user, group
  externalThreadId  String?   @map("external_thread_id")
  // Group-specific (chỉ set khi threadType=group; resolve qua getGroupInfo từ zca-js)
  groupName         String?   @map("group_name")
  groupAvatarUrl    String?   @map("group_avatar_url")
  groupMembersCount Int?      @map("group_members_count")
  lastMessageAt     DateTime? @map("last_message_at")
  unreadCount       Int       @default(0) @map("unread_count")
  isReplied         Boolean   @default(true) @map("is_replied")
  tab               String    @default("main") @map("tab") // main, other
  createdAt         DateTime  @default(now()) @map("created_at")

  org           Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount   ZaloAccount          @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact       Contact?             @relation(fields: [contactId], references: [id])
  messages      Message[]
  aiSuggestions AiSuggestion[]
  pins          PinnedConversation[]

  @@unique([zaloAccountId, externalThreadId])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  // M-tier tab-switch fix (2026-05-21): index riêng cho tab Cá Nhân/Nhóm
  // (filter theo threadType + accountId, sort lastMessageAt desc).
  // Trước fix: planner seq-scan + filter post-index → 1-3s lag chuyển tab.
  @@index([orgId, threadType, zaloAccountId, lastMessageAt(sort: Desc)])
  // Tab Chính/Khác: filter tab + accountId, sort lastMessageAt desc.
  @@index([orgId, tab, zaloAccountId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  // Numeric Snowflake từ Zalo server — primary sort key (match 100% Zalo Web).
  // sentAt giữ làm display + fallback cho CRM-sent chưa echo. KHÔNG dùng sentAt làm
  // primary order vì self-listen events đôi khi thiếu `ts` → Date.now() fallback lệch ~30s.
  zaloMsgIdNum    BigInt?   @map("zalo_msg_id_num")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  quote           Json?     @map("quote")
  albumKey        String?   @map("album_key") // Zalo group_layout_id — identifies multi-image albums
  albumIndex      Int?      @map("album_index") // 0-based position within album
  albumTotal      Int?      @map("album_total") // total items in album
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  // Edit message audit (2026-05-21) — zca-js không support edit thật, edit chỉ áp dụng trên CRM.
  // Khi sửa: lưu content cũ vào originalContent (lần đầu) + set editedAt = now.
  originalContent String?   @map("original_content")
  editedAt        DateTime? @map("edited_at")
  // Zalo client message id (2026-05-21) — KHÁC zaloMsgId (server snowflake). Cần cho api.undo
  // (Zalo expect cả msgId + cliMsgId). Tin cũ trước migration chưa có column này → null.
  zaloCliMsgId    String?   @map("zalo_cli_msg_id")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?             @relation("RepliedMessages", fields: [repliedByUserId], references: [id])
  reactions    MessageReaction[]

  @@unique([conversationId, zaloMsgId])
  @@index([conversationId, albumKey])
  // Composite index cho sort theo Zalo Snowflake — primary order khi list messages.
  @@index([conversationId, zaloMsgIdNum(sort: Desc)])
  @@map("messages")
}

// Appointment scheduled for a contact
// source='zalo' khi sync từ reminder Zalo client, source='manual' khi sale tạo trong CRM.
// externalRef = Zalo reminderId (unique per org để dedup khi reminder edit/fire lại).
// zaloMessageId = FK mềm tới Message.id của reminder card → deep-link conversation.
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  // 2026-05-21 "Nhắc hẹn" refactor — anh chốt 1 modal cho create+edit:
  //   title       — tiêu đề (default = "Gọi nhắc KH X")
  //   durationMin — dự kiến dành thời gian (phút), endAt tính ngầm = startAt + duration
  //   location    — địa điểm (5 preset chips + smart suggest từ title)
  //   type        — 4 values: call | message | meeting | follow_up
  title           String?
  durationMin     Int      @default(15) @map("duration_min")
  location        String?
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  // Nguồn + link Zalo
  source        String  @default("manual") // "manual" | "zalo"
  externalRef   String? @map("external_ref") // Zalo reminderId (params.actions[0].data.reminderId)
  zaloMessageId String? @map("zalo_message_id") // FK mềm → Message.id (không cascade, giữ data nếu msg xoá)
  emoji         String? // ⏰ 🔔 từ params hoặc default

  // Status audit — track ai đổi status cuối cùng + lúc nào (cron auto-flip không set)
  statusChangedByUserId String?   @map("status_changed_by_user_id")
  statusChangedAt       DateTime? @map("status_changed_at")
  statusChangedBy       User?     @relation("AppointmentStatusChanger", fields: [statusChangedByUserId], references: [id])

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])
  fromNotes    Note[]       @relation("NoteAppointment")

  @@unique([orgId, externalRef])
  @@index([source])
  @@index([orgId, appointmentDate])
  @@map("appointments")
}

// CRM-style notes on a contact — Facebook-comment-like with flat thread (parentNoteId nullable, depth=1).
// Manager có thể reply vào note của sale. Reaction emoji per (note, user, emoji).
// AI có thể parse note body ("Thứ 6 gọi lại khách") → suggest Appointment (linked via Appointment.noteId).
model Note {
  id                     String   @id @default(uuid())
  orgId                  String   @map("org_id")
  contactId              String   @map("contact_id")
  parentNoteId           String?  @map("parent_note_id") // null = root note, set = reply (chỉ 1 cấp)
  authorUserId           String   @map("author_user_id")
  body                   String   @db.Text
  // Khi user bấm "🤖 Tạo lịch hẹn" trên note → set FK tới appointment được tạo.
  // Cho phép hiện badge "đã tạo lịch" trên note + tránh tạo trùng.
  suggestedAppointmentId String?  @map("suggested_appointment_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author      User           @relation("NoteAuthor", fields: [authorUserId], references: [id])
  parent      Note?          @relation("NoteThread", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies     Note[]         @relation("NoteThread")
  reactions   NoteReaction[]
  appointment Appointment?   @relation("NoteAppointment", fields: [suggestedAppointmentId], references: [id], onDelete: SetNull)

  @@index([orgId, contactId, createdAt])
  @@index([parentNoteId])
  @@map("notes")
}

// CRM tag — tag SYSTEM-LEVEL do org tự định nghĩa (vd "vip", "quan_tâm", "hot_lead").
// Khác ZaloLabel (Zalo native, sync 2-way với Zalo SDK).
// Contact.tags JSON array of strings tham chiếu CrmTag.name. Nếu name không match
// trong CrmTag table → vẫn cho lưu (free-text) nhưng FE hint user thêm vào table.
model CrmTag {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  name              String // unique per org, dùng làm reference key
  color             String    @default("#90A4AE") // hex color
  emoji             String? // optional unicode emoji prefix
  description       String? // mô tả mục đích, vd "Khách quan tâm dự án EGV"
  category          String? // LEGACY: gom nhóm string-based. Mới: dùng groupId
  groupId           String?   @map("group_id") // FK CrmTagGroup — gom nhóm formal
  managedBy         String?   @map("managed_by") // null | 'zalo_sync' — Zalo-managed tag read-only trong UI CRM
  sourceZaloLabelId Int?      @map("source_zalo_label_id") // ZaloLabel.zaloLabelId nếu managedBy='zalo_sync'
  archivedAt        DateTime? @map("archived_at") // soft delete khi Zalo label bị xoá
  order             Int       @default(0) // sort order trong settings
  isActive          Boolean   @default(true) @map("is_active")
  usageCount        Int       @default(0) @map("usage_count") // denorm — cập nhật khi recompute
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group CrmTagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([orgId, name])
  @@unique([sourceZaloLabelId]) // 1 Zalo label → 1 CrmTag mirror
  @@index([orgId, category])
  @@index([orgId, groupId])
  @@index([managedBy, archivedAt])
  @@map("crm_tags")
}

// Tag group — gom các CrmTag thuộc cùng "nhóm" (formal hơn category string).
// 2 use case: (1) user-defined group, (2) zalo-managed group auto-tạo từ Zalo nick.
// managedBy='zalo_sync' + zaloAccountId set → group được tạo+maintain tự động khi sync.
model CrmTagGroup {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  name          String // vd "Zalo - Phạm Thành CSKH (0912345678)" hoặc "Mức độ"
  managedBy     String?   @map("managed_by") // null | 'zalo_sync'
  zaloAccountId String?   @map("zalo_account_id") // set nếu managedBy='zalo_sync'
  order         Int       @default(0)
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount? @relation(fields: [zaloAccountId], references: [id], onDelete: SetNull)
  tags        CrmTag[]

  @@unique([orgId, name])
  @@unique([zaloAccountId, managedBy]) // 1 Zalo account chỉ có 1 zalo_sync group
  @@index([orgId, archivedAt])
  @@map("crm_tag_groups")
}

// Per-user preferences (timeline filter, UI toggles, ...).
// Key/value JSON store, scoped userId. Cross-device sync khi user đăng nhập máy khác.
model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String // vd "timeline.categories.visible"
  value     Json     @default("null")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

// Zalo native labels — synced từ Zalo SDK getLabels() per nick.
// 1 label = (zaloAccountId, zaloLabelId). conversations[] là list externalThreadId
// được assign label đó. Update qua SDK updateLabels({labelData, version}).
// Settings page hiển thị bảng + cho phép edit color/text → write back qua SDK.
model ZaloLabel {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  zaloAccountId String   @map("zalo_account_id")
  zaloLabelId   Int      @map("zalo_label_id") // numeric ID từ Zalo
  textKey       String   @map("text_key") // SDK textKey field
  text          String // tên label hiển thị
  color         String // hex from SDK
  emoji         String? // unicode emoji
  offset        Int      @default(0) // sort order trong Zalo client
  version       Int      @default(0) // server-version của bulk
  conversations Json     @default("[]") // string[] externalThreadId
  createTime    BigInt?  @map("create_time") // SDK epoch
  syncedAt      DateTime @default(now()) @map("synced_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, zaloLabelId])
  @@index([orgId, zaloAccountId])
  @@map("zalo_labels")
}

// Emoji reaction trên 1 note. 1 user có thể reaction nhiều emoji khác nhau, không trùng cùng 1 emoji.
model NoteReaction {
  id        String   @id @default(uuid())
  noteId    String   @map("note_id")
  userId    String   @map("user_id")
  emoji     String // 1 emoji unicode: 👍 ❤️ 😂 😮 😢 🎉 ...
  createdAt DateTime @default(now()) @map("created_at")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId, emoji])
  @@index([noteId])
  @@map("note_reactions")
}

// Audit trail — log MỌI mutation CRM với actor + category + diff.
// Source of truth cho timeline + activity log page.
// Actor 3 loại: user (sale/admin), bot (automation), system (migration/sync).
// Category 9 nhóm: customer_info, tags_crm, tags_zalo, status_care, score,
//   appointment, interaction, system, automation.
model ActivityLog {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  userId       String?  @map("user_id") // null nếu actorType != 'user'
  actorType    String   @default("user") @map("actor_type") // 'user' | 'bot' | 'system'
  botName      String?  @map("bot_name") // vd "AutoTag Bot" — chỉ khi actorType='bot'
  systemSource String?  @map("system_source") // vd "zalo_label_sync" — chỉ khi actorType='system'
  category     String? // 9 nhóm — null cho legacy rows
  action       String
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id")
  details      Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  // Composite indexes cho timeline query (entity per-customer) + activity log page
  // (filter category + date range). Sort DESC vì 99% query là "latest first".
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([orgId, category, createdAt(sort: Desc)])
  @@index([orgId, actorType, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// External service integration (Google Sheets, Telegram, Facebook, Zapier)
model Integration {
