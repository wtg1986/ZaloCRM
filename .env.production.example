# ─────────────────────────────────────────────────────────────────────────────
# .env.production — BACKEND stack (docker-compose.prod.yml) trên elest.io / VPS.
# Copy thành .env.production và điền giá trị thật. KHÔNG commit file thật.
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Bảo mật (BẮT BUỘC, tối thiểu 32 ký tự — production fail-fast nếu thiếu/yếu) ──
# Sinh bằng: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# ── Database (Postgres trong compose) ────────────────────────────────────────
DB_USER=crmuser
DB_PASSWORD=            # BẮT BUỘC — đặt mật khẩu mạnh
DB_NAME=zalocrm
# DATABASE_URL được compose tự dựng từ DB_* (trỏ host "db"). Không cần điền tay.

# ── CORS: domain Frontend trên Vercel (BẮT BUỘC) ─────────────────────────────
# Nhiều domain phân tách bằng dấu phẩy, vd: https://app.yourdomain.com,https://yourdomain.com
APP_URL=https://your-app.vercel.app
# Cho phép mọi preview *.vercel.app (chỉ bật khi cần test nhánh): true/false
CORS_ALLOW_VERCEL_PREVIEW=false

# ── Object storage (MinIO trong compose) ─────────────────────────────────────
MINIO_ROOT_USER=               # BẮT BUỘC
MINIO_ROOT_PASSWORD=           # BẮT BUỘC (mạnh)
S3_BUCKET=zalocrm-attachments
# S3_ENDPOINT nội bộ (backend → minio). Để mặc định.
S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_URL: URL HTTPS CÔNG KHAI browser + Zalo CDN tải ảnh được.
# Map 1 subdomain trên elest.io → cổng 9000 của minio, vd:
S3_PUBLIC_URL=https://storage.yourdomain.com
# (S3_ACCESS_KEY/S3_SECRET_KEY mặc định lấy theo MINIO_ROOT_USER/PASSWORD)

# ── Redis: REDIS_URL được compose set sẵn (redis://redis:6379) ────────────────

# ── AI providers (tùy chọn — điền nếu dùng AI Agent) ─────────────────────────
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_AUTH_TOKEN=
GEMINI_DEFAULT_PRO_MODEL=gemini-2.5-pro
GEMINI_DEFAULT_FLASH_MODEL=gemini-2.5-flash
ANTHROPIC_AUTH_TOKEN=

# ── Khác ─────────────────────────────────────────────────────────────────────
AUTOMATION_STUB_MODE=false
